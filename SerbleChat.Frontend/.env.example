# Base URL of the backend API
VITE_API_BASE_URL=http://localhost:5210

# Public-facing URL of this frontend (used for invite links and message links)
# Defaults to window.location.origin if not set
VITE_FRONTEND_URL=http://localhost:5173

# URL the frontend should use to connect to the LiveKit server (WebSocket URL)
VITE_LIVEKIT_URL=ws://localhost:7880

# URL of the S3 endpoint for loading images
VITE_S3_ENDPOINT=https://s3.serble.net/serblechat-images
